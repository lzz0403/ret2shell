{
  "useTabs": false,
  "singleQuote": true,
  "trailingComma": "es5",
  "printWidth": 120,
  "plugins": ["prettier-plugin-svelte"],
  "semi": false,
  "overrides": [
    {
      "files": "*.svelte",
      "options": {
        "parser": "svelte"
      }
    }
  ],
  "bracketSpacing": true,
  "htmlWhitespaceSensitivity": "ignore"
}
